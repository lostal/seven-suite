@startuml seqRegistrarVisitante

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam sequenceArrowThickness 1.2
skinparam sequenceArrowColor #444444
skinparam participantBorderThickness 1.5
skinparam backgroundColor #FFFFFF

title Secuencia: registrarVisitante()

actor "Empleado" as U
participant "Página RSC\n/parking/visitantes" as Page
participant "Formulario de visita\n(componente cliente)" as CC
participant "createVisitorReservation()\nServer Action" as SA
participant "Auth + Config\n(helpers / config.ts)" as AuthCfg
participant "Base de datos\n(Drizzle + PostgreSQL)" as DB
participant "Resend\n(API de email)" as Email

U -> Page : accede a /parking/visitantes
Page -> DB : consulta visitas próximas del empleado
DB --> Page : ReservaVisitante[]
Page --> U : lista de visitas + botón "Nueva visita"

U -> CC : pulsa "Nueva visita"
CC -> DB : consulta plazas de visitante disponibles (fecha)
DB --> CC : [{ id, etiqueta }]
CC --> U : muestra formulario con plazas disponibles

U -> CC : rellena datos (nombre, empresa, email, fecha, plaza)
U -> CC : confirma

CC -> SA : createVisitorReservation({ spotId, fecha, nombreVisitante, ... })
SA -> AuthCfg : obtiene usuario autenticado + config del módulo
AuthCfg --> SA : AuthUser · ResourceConfig

SA -> DB : INSERT INTO visitor_reservations
alt plaza ya reservada ese día
  DB --> SA : violación de índice único
  SA --> CC : Error — plaza ya tiene reserva de visitante ese día
else inserción exitosa
  DB --> SA : { id }
  SA -> Email : envía email al visitante (fecha, plaza, .ics adjunto)
  Email --> SA : enviado
  SA -> DB : UPDATE notification_sent = true
  SA -> SA : revalidatePath("/parking/visitantes")
  SA --> CC : OK — { id: reservaId }
end

CC --> U : confirmación con datos de la visita o error

note right of Email
  El visitante recibe el email
  con la fecha, la plaza y un
  archivo .ics adjunto.
  No tiene acceso al portal.
end note

@enduml
