@startuml paquetes

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam packageBorderThickness 1.5
skinparam arrowThickness 1.2
skinparam arrowColor #444444
skinparam backgroundColor #FFFFFF

skinparam package {
  BackgroundColor<<modulo>>  #d5ecd4
  BorderColor<<modulo>>      #2e7d32
  BackgroundColor<<lib>>     #fde8cc
  BorderColor<<lib>>         #c45e0a
  BackgroundColor<<core>>    #dce8f5
  BorderColor<<core>>        #2d6a9f
  BackgroundColor<<shared>>  #f5f0d5
  BorderColor<<shared>>      #9c8c10
}

title Diagrama de paquetes

package "src/app/(auth)/" <<core>> as Auth

package "src/app/(dashboard)/" <<core>> as Dashboard {
  package "parking/" <<modulo>> as PKG_P
  package "oficinas/" <<modulo>> as PKG_O
  package "vacaciones/" <<modulo>> as PKG_V
  package "tablon/" <<modulo>> as PKG_T
  package "administracion/" <<modulo>> as PKG_A
  package "ajustes/" <<modulo>> as PKG_AJ
  package "panel/" <<modulo>> as PKG_PAN
}

package "src/lib/" <<lib>> as Lib {
  package "db/" <<lib>> as DB
  package "auth/" <<lib>> as LIB_AUTH
  package "queries/" <<lib>> as Queries
  package "actions/" <<lib>> as SharedActions
  package "calendar/" <<lib>> as Calendar
}

package "src/components/" <<shared>> as Components
package "src/types/" <<shared>> as Types

' ── Dependencias ─────────────────────────────────────────────
Dashboard  ..> Lib        : importa lógica compartida
Dashboard  ..> Components : importa componentes UI
Dashboard  ..> Types      : tipos de la aplicación

PKG_P  ..> SharedActions  : buildCessionActions("parking")
PKG_O  ..> SharedActions  : buildCessionActions("office")

SharedActions ..> Queries
SharedActions ..> LIB_AUTH
Queries       ..> DB
Lib           ..> Types

note bottom of DB
  schema.ts es la fuente única de verdad.
  Los tipos de la app se infieren de él.
end note

@enduml
