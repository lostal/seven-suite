@startuml arqCapas

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam rectangleBorderThickness 1.5
skinparam arrowThickness 1.2
skinparam arrowColor #444444
skinparam backgroundColor #FFFFFF

skinparam rectangle {
  BackgroundColor<<presentacion>> #dce8f5
  BorderColor<<presentacion>>    #2d6a9f
  BackgroundColor<<aplicacion>>  #d5ecd4
  BorderColor<<aplicacion>>      #2e7d32
  BackgroundColor<<dominio>>     #fde8cc
  BorderColor<<dominio>>         #c45e0a
  BackgroundColor<<persistencia>> #f5f0d5
  BorderColor<<persistencia>>    #9c8c10
  BackgroundColor<<externo>>     #efefef
  BorderColor<<externo>>         #888888
}

title Capas lógicas del sistema

rectangle "**Presentación**\nPáginas servidor (RSC) · Componentes cliente · shadcn/ui" <<presentacion>> as P
rectangle "**Aplicación**\nServer Actions · Validación Zod · Guardas de rol · Caché de config" <<aplicacion>> as A
rectangle "**Dominio**\nQueries Drizzle · Validación de reservas · Utilidades de calendario" <<dominio>> as D
rectangle "**Persistencia**\nDrizzle ORM · schema.ts (fuente única de verdad) · PostgreSQL 16" <<persistencia>> as DB
rectangle "**Servicios externos**\nMicrosoft Entra ID (SSO) · Microsoft Graph · Resend (email)" <<externo>> as EXT

P  -down-> A   : llama a Server Actions
A  -down-> D   : invoca queries
D  -down-> DB  : consultas Drizzle
A  -right-> EXT : OAuth · Graph API · email

@enduml
