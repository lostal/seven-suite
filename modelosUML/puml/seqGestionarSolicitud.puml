@startuml seqGestionarSolicitud

skinparam backgroundColor #FFFFFF
skinparam linetype polyline
skinparam defaultFontName Arial
skinparam defaultFontSize 10
skinparam sequenceArrowThickness 1.5
skinparam participantBorderThickness 1.5
skinparam shadowing false

actor RRHH as R
participant "BandejaSolicitudes\nPage" as Page
participant "approveLeaveRequest\n(Server Action)" as Action
database "PostgreSQL" as DB

R -> Page: abre bandeja

Page -> Page: carga solicitudes pendientes\n(filtro: entity_id)

Page --> R: solicitudes de la entidad

R -> Page: selecciona solicitud\n+ aprueba con nota

Page -> Action: approveLeaveRequest({ id, notes })

Action -> Action: requireHROrAbove()\nausenciaSchema.parse(input)

Action -> DB: transita a approved

Action --> Page: ActionResult<LeaveRequest>

@enduml
