@startuml cuRegistrarVisitante

skinparam linetype polyline
skinparam defaultFontName Arial
skinparam defaultFontSize 10

state registrarVisitante as "registrarVisitante()" {
  state " " as IntroduciendoDatos
  state " " as SeleccionandoPlaza
  state " " as VisitanteRegistrado

  [*] -[#green]-> IntroduciendoDatos
  note on link
    <b>Empleado</b> solicita registrar visitante
  end note

  IntroduciendoDatos -[#green]-> SeleccionandoPlaza
  note on link
    <b>Sistema</b> presenta formulario de registro
    • Nombre, empresa y email del visitante
    • Fecha de la visita
    • Permite solicitar continuar
    • Permite solicitar cancelar
  end note

  SeleccionandoPlaza -[#green]-> VisitanteRegistrado
  note on link
    <b>Sistema</b> presenta plazas de visitante disponibles para la fecha
    • Plazas de visitante libres
    • Capacidad y ubicación
    • Permite solicitar confirmar registro
    • Permite solicitar cancelar
  end note

  VisitanteRegistrado -[#green]-> [*]
  note on link
    <b>Empleado</b> solicita confirmar registro
    <b>Sistema</b> crea reserva de visitante y transfiere a calendario
  end note
}

registrarVisitante -[#green]-> CALENDARIO_PARKING_ABIERTO
note on link
  visitante registrado
end note

registrarVisitante -[#blue]-> CALENDARIO_PARKING_ABIERTO
note on link
  cancelar
end note

@enduml
