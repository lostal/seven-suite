@startuml seqAprobarSolicitudAusencia

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam sequenceArrowThickness 1.2
skinparam sequenceArrowColor #444444
skinparam participantBorderThickness 1.5
skinparam backgroundColor #FFFFFF

title Secuencia: aprobarSolicitudAusencia()

actor "Manager / RRHH" as U
participant "Página RSC\n/vacaciones/gestionar" as Page
participant "Tabla de solicitudes\n(componente cliente)" as CC
participant "approveLeaveRequest()\nServer Action" as SA
participant "Auth\n(helpers.ts)" as Auth
participant "Base de datos\n(Drizzle + PostgreSQL)" as DB

U -> Page : accede a /vacaciones/gestionar
Page -> DB : consulta solicitudes del manager/RRHH
DB --> Page : SolicitudAusencia[]
Page --> U : tabla de solicitudes pendientes

U -> CC : selecciona solicitud y pulsa "Aprobar"
CC --> U : panel de detalle con campo de notas (opcional)
U -> CC : introduce notas y confirma

CC -> SA : approveLeaveRequest({ id, notas })
SA -> Auth : getCurrentUser()
Auth --> SA : AuthUser { id, perfil: { rol } }

alt rol sin permisos (empleado)
  SA --> CC : Error — sin permisos
else
  SA -> DB : consulta estado actual de la solicitud
  DB --> SA : { estado }

  alt manager Y estado = pendiente
    SA -> DB : UPDATE estado → aprobada_manager
    DB --> SA : OK
    SA -> SA : revalidatePath("/vacaciones/gestionar")
    SA --> CC : OK — { nuevoEstado: aprobada_manager }
  else RRHH/admin Y estado = aprobada_manager
    SA -> DB : UPDATE estado → aprobada_rrhh
    DB --> SA : OK
    SA -> SA : revalidatePath("/vacaciones/gestionar")
    SA --> CC : OK — { nuevoEstado: aprobada_rrhh }
  else transición inválida
    SA --> CC : Error — no puedes aprobar en el estado actual
  end
end

CC --> U : actualiza estado en tabla o muestra error

@enduml
